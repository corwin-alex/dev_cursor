{
  "name": "learning-progress-tracker",
  "version": "1.0.0",
  "description": "Simple course learning and progress tracker",
  "main": "src/server/server.js",
  "scripts": {
    "build": "webpack --mode production",
    "dev:client": "webpack --mode development --watch",
    "start": "node src/server/server.js",
    "dev": "concurrently \"npm:dev:client\" \"npm:start\""
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "react",
    "express",
    "sqlite",
    "webpack"
  ],
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.25.9",
    "babel-loader": "^9.2.1",
    "concurrently": "^9.1.0",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.3",
    "sass": "^1.80.6",
    "sass-loader": "^16.0.2",
    "style-loader": "^4.0.0",
    "webpack": "^5.96.1",
    "webpack-cli": "^5.1.4"
  }
}
